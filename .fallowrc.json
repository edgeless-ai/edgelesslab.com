{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "ignorePatterns": [
    "public/tartanism/app/assets/**",
    "tartanism/app/assets/**",
    "**/*.bundle.js",
    "**/*.chunk.js",
    "public/flow-viz/**",
    "_next/**",
    "docs/source-refs/**",
    "**/*.min.js",
