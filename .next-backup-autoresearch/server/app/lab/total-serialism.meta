{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/lab/layout,_N_T_/lab/[slug]/layout,_N_T_/lab/[slug]/page,_N_T_/lab/total-serialism"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/lab/$d$slug/__PAGE__",
    "/lab/$d$slug",
    "/lab",
    "/_index",
    "/_head"
  ]
}