{
  "name": "edgeless-scaffold",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "./scripts/preserve-standalone.sh save",
    "build": "next build",
    "postbuild": "find out -name '*.js.map' -delete && find out -name '*.css.map' -delete && ./scripts/preserve-standalone.sh restore && mkdir -p out/pen-plotter/assets && rsync -a --exclude=medium --exclude=mediums-all pen-plotter/assets/ out/pen-plotter/assets/; [ -d pen-plotter/fxhash ] && cp -r pen-plotter/fxhash out/pen-plotter/; [ -d pen-plotter/kandinsky-to-canvas ] && cp -r pen-plotter/kandinsky-to-canvas out/pen-plotter/; npx pagefind --site out; true",
    "start": "next start",
    "lint": "eslint && node scripts/lint-experiments.mjs && npm run lint:voice",
    "lint:blog-links": "node scripts/lint-blog-links.mjs",
    "lint:experiments": "node scripts/lint-experiments.mjs",
    "lint:voice": "../scripts/lint-voice.sh src/lib/data.ts && ../scripts/lint-voice.sh src/lib/product-content.ts && ../scripts/lint-voice.sh src/lib/blog.ts",
    "worker:ingest:dev": "npx wrangler dev --config workers/ingest/wrangler.toml",
    "worker:ingest:deploy": "npx wrangler deploy --config workers/ingest/wrangler.toml"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.8",
    "@paper-design/shaders-react": "^0.0.76",
    "lucide-react": "^0.577.0",
    "motion": "^12.42.2",
    "next": "16.2.10",
    "posthog-js": "^1.363.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tldraw": "^3.15.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "pagefind": "^1.5.2",
    "playwright": "^1.44.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
