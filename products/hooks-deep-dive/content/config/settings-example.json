{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/damage-control.py"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/damage-control.py"
          },
          {
            "type": "command",
            "command": ".claude/hooks/validate-taxonomy.py"
          },
          {
            "type": "command",
            "command": ".claude/hooks/check-hook-registry.py"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/damage-control.py"
          },
          {
            "type": "command",
            "command": ".claude/hooks/validate-taxonomy.py"
          },
          {
            "type": "command",
            "command": ".claude/hooks/check-hook-registry.py"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/damage-control.py"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/skill-activation.py"
          },
          {
            "type": "command",
            "command": ".claude/hooks/inbox-auto-claim.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-tool-tracker.py"
          },
          {
            "type": "command",
            "command": ".claude/hooks/webfetch-archive.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/loop-stop-hook.py"
          },
          {
            "type": "command",
            "command": ".claude/hooks/session-end.py"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-compact.py"
          }
        ]
      }
    ]
  }
}
