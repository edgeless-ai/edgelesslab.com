# n8n AI Workflow Templates — Environment Configuration
# Copy this file to .env and fill in your values.

# ─── n8n Authentication ───
# Create these credentials on first login at localhost:5678
N8N_BASIC_AUTH_USER=admin@localhost.com
N8N_BASIC_AUTH_PASSWORD=change_me_immediately

# ─── Database ───
POSTGRES_USER=n8n
POSTGRES_PASSWORD=n8n_password
POSTGRES_DB=n8n

# ─── Timezone ───
TIMEZONE=America/Los_Angeles

# ─── API Keys ───
# Google Gemini (required for digest generation and style transfer)
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI (optional, for alternative LLM routing)
# OPENAI_API_KEY=your_openai_api_key_here

# ─── YouTube Workflow ───
# Comma-separated YouTube channel IDs to monitor
# YOUTUBE_CHANNEL_IDS=UCxxxxxxx,UCyyyyyyy

# ─── RSS Workflow ───
# RSS feeds are configured inside the workflow JSON.
# Edit the RSS Feed Read node after import to add your feeds.

# ─── Email (optional, for digest delivery) ───
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM=your_email@gmail.com
